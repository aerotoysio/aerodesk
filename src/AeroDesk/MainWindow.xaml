<Window x:Class="AeroDesk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ad="https://github.com/Dirkster99/AvalonDock"
        xmlns:adcontrols="clr-namespace:AvalonDock.Controls;assembly=AvalonDock"
        xmlns:vm="clr-namespace:AeroDesk.ViewModels"
        xmlns:vmsale="clr-namespace:AeroDesk.ViewModels.Sale"
        xmlns:vmorders="clr-namespace:AeroDesk.ViewModels.Orders"
        xmlns:vmops="clr-namespace:AeroDesk.ViewModels.Operations"
        xmlns:views="clr-namespace:AeroDesk.Views"
        Title="AeroDesk"
        Height="760" Width="1200"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Navigation tree node templates -->
        <HierarchicalDataTemplate DataType="{x:Type vm:ConnectionNodeViewModel}" ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal">
                <StackPanel.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Seed demo data" Command="{Binding SeedDemoDataCommand}"/>
                        <Separator/>
                        <MenuItem Header="Disconnect" Command="{Binding DisconnectCommand}"/>
                    </ContextMenu>
                </StackPanel.ContextMenu>
                <TextBlock Text="{Binding Glyph}" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
            </StackPanel>
        </HierarchicalDataTemplate>

        <HierarchicalDataTemplate DataType="{x:Type vm:ActionNodeViewModel}" ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Background="Transparent">
                <StackPanel.InputBindings>
                    <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding OpenCommand}"/>
                </StackPanel.InputBindings>
                <StackPanel.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Open" Command="{Binding OpenCommand}"/>
                    </ContextMenu>
                </StackPanel.ContextMenu>
                <TextBlock Text="{Binding Glyph}" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding Name}"/>
            </StackPanel>
        </HierarchicalDataTemplate>

        <HierarchicalDataTemplate DataType="{x:Type vm:MessageNodeViewModel}" ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Glyph}" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding Name}" Foreground="DarkRed" TextWrapping="Wrap" MaxWidth="240"/>
            </StackPanel>
        </HierarchicalDataTemplate>

        <!-- Document (tab) content templates -->
        <DataTemplate DataType="{x:Type vmsale:SaleDocumentViewModel}">
            <views:SaleView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vmorders:OrdersDocumentViewModel}">
            <views:OrdersView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vmorders:OrderDetailDocumentViewModel}">
            <views:OrderDetailView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vmops:DeparturesDocumentViewModel}">
            <views:DeparturesView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vmops:FlightDocumentViewModel}">
            <views:FlightView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:WelcomeDocumentViewModel}">
            <ScrollViewer>
                <StackPanel Margin="40" MaxWidth="640" HorizontalAlignment="Left">
                    <TextBlock Text="AeroDesk" FontSize="30" FontWeight="Light"/>
                    <TextBlock Text="Airline call-centre agent desktop — IATA Offers &amp; Orders (NDC)"
                               FontSize="14" Foreground="Gray" Margin="0,4,0,24"/>
                    <TextBlock FontSize="13" TextWrapping="Wrap" Margin="0,0,0,12">
                        Sign in with your agent account to connect to AeroBus. Then open
                        <Run FontWeight="SemiBold" Text="New Sale"/>
                        to search flights, compare branded fares and take (simulated) payment —
                        or <Run FontWeight="SemiBold" Text="Orders"/>
                        to retrieve, change, and cancel existing bookings.
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="🔌  Connect…" Command="{Binding DataContext.ConnectCommand,
                                RelativeSource={RelativeSource AncestorType=Window}}" Padding="12,6"/>
                    </StackPanel>
                    <TextBlock FontSize="11" Foreground="#999" TextWrapping="Wrap" Margin="0,28,0,0">
                        Demo software: payments are simulated through a mock, tokenized gateway.
                        No real card data is ever accepted or stored.
                    </TextBlock>
                </StackPanel>
            </ScrollViewer>
        </DataTemplate>
    </Window.Resources>

    <DockPanel>
        <!-- Menu -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Connect…" Command="{Binding ConnectCommand}"/>
                <Separator/>
                <MenuItem Header="_Export Settings…" Command="{Binding ExportSettingsCommand}"/>
                <MenuItem Header="_Import Settings…" Command="{Binding ImportSettingsCommand}"/>
                <Separator/>
                <MenuItem Header="E_xit" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About AeroDesk" Command="{Binding AboutCommand}"/>
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <Button Command="{Binding ConnectCommand}" ToolTip="Sign in to AeroBus">🔌 Connect</Button>
            </ToolBar>
        </ToolBarTray>

        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding VersionText}" Foreground="Gray"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Docking area: navigation (left) + document tabs (right) -->
        <ad:DockingManager x:Name="DockManager"
                           DocumentsSource="{Binding Documents}"
                           ActiveContent="{Binding ActiveDocument, Mode=TwoWay}"
                           DocumentClosed="OnDocumentClosed">
            <ad:DockingManager.LayoutItemContainerStyle>
                <Style TargetType="{x:Type adcontrols:LayoutItem}">
                    <Setter Property="Title" Value="{Binding Model.Title}"/>
                    <Setter Property="ContentId" Value="{Binding Model.ContentId}"/>
                    <Setter Property="CanClose" Value="{Binding Model.CanClose}"/>
                    <Setter Property="IsSelected" Value="{Binding Model.IsSelected, Mode=TwoWay}"/>
                    <Setter Property="IsActive" Value="{Binding Model.IsActive, Mode=TwoWay}"/>
                </Style>
            </ad:DockingManager.LayoutItemContainerStyle>
            <ad:LayoutRoot>
                <ad:LayoutPanel Orientation="Horizontal">
                    <ad:LayoutAnchorablePane DockWidth="300">
                        <ad:LayoutAnchorable Title="Connections" CanClose="False" CanHide="False"
                                             ContentId="connections">
                            <TreeView ItemsSource="{Binding Connections}" BorderThickness="0">
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem">
                                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                    </Style>
                                </TreeView.ItemContainerStyle>
                            </TreeView>
                        </ad:LayoutAnchorable>
                    </ad:LayoutAnchorablePane>
                    <ad:LayoutDocumentPane/>
                </ad:LayoutPanel>
            </ad:LayoutRoot>
        </ad:DockingManager>
    </DockPanel>
</Window>
