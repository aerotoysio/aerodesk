<Window x:Class="AeroDesk.Views.ConnectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Connect — AeroDesk"
        Width="480" SizeToContent="Height" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <StackPanel Margin="16">
        <TextBlock Text="Retailing backend" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>

        <RadioButton x:Name="DfRadio" Content="DocumentForge node (order store)" IsChecked="True" Margin="0,0,0,4"/>
        <RadioButton x:Name="AeroBusRadio" Content="AeroBus backbone (agent login)" Margin="0,0,0,4"/>
        <RadioButton x:Name="OfflineRadio" Content="Offline demo (in-memory, nothing persisted)" Margin="0,0,0,12"/>

        <Border x:Name="AeroBusPanel" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Padding="12"
                Visibility="Collapsed" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="URL:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="AbUrlBox" Margin="0,0,0,8" Text="http://localhost:5080"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Company slug:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="AbSlugBox" Margin="0,0,0,8" Text="aerotoys"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Agent email:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="AbEmailBox" Margin="0,0,0,8"/>
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Password:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                <PasswordBox Grid.Row="3" Grid.Column="1" x:Name="AbPasswordBox" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="4" Grid.ColumnSpan="2" Text="Departure control (Keycloak staff login) — optional"
                           FontWeight="SemiBold" Foreground="#6B7280" Margin="0,4,0,6"/>
                <TextBlock Grid.Row="5" Grid.Column="0" Text="Keycloak URL:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                <TextBox Grid.Row="5" Grid.Column="1" x:Name="AbKcUrlBox" Margin="0,0,0,8"
                         ToolTip="e.g. http://localhost:8080 — leave blank to skip departure control"/>
                <TextBlock Grid.Row="6" Grid.Column="0" Text="Realm:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                <TextBox Grid.Row="6" Grid.Column="1" x:Name="AbKcRealmBox" Margin="0,0,0,8" Text="aerotoys"/>
                <TextBlock Grid.Row="7" Grid.Column="0" Text="Client id:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                <TextBox Grid.Row="7" Grid.Column="1" x:Name="AbKcClientBox" Margin="0,0,0,8" Text="aeroboard"/>

                <CheckBox Grid.Row="8" Grid.Column="1" x:Name="AbSaveCheck" Content="Save this connection" IsChecked="True"/>
            </Grid>
        </Border>

        <Border x:Name="DfPanel" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Saved:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                <ComboBox Grid.Row="0" Grid.Column="1" x:Name="SavedCombo" Margin="0,0,0,8"
                          DisplayMemberPath="Name" SelectionChanged="OnSavedSelected"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Name:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="NameBox" Margin="0,0,0,8"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="URL:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="UrlBox" Margin="0,0,0,8" Text="http://localhost:5001"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Database:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                <TextBox Grid.Row="3" Grid.Column="1" x:Name="DatabaseBox" Margin="0,0,0,8" Text="airline"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="API key:" VerticalAlignment="Center" Margin="0,0,8,8"/>
                <PasswordBox Grid.Row="4" Grid.Column="1" x:Name="ApiKeyBox" Margin="0,0,0,8"/>

                <CheckBox Grid.Row="5" Grid.Column="1" x:Name="SaveCheck" Content="Save this connection" IsChecked="True"/>
            </Grid>
        </Border>

        <TextBlock x:Name="ErrorText" Foreground="DarkRed" TextWrapping="Wrap" Margin="0,8,0,0"
                   Visibility="Collapsed"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Connect" IsDefault="True" Padding="16,6" Margin="0,0,8,0" Click="OnConnect"/>
            <Button Content="Cancel" IsCancel="True" Padding="16,6"/>
        </StackPanel>
    </StackPanel>
</Window>
