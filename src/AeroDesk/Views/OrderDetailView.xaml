<UserControl x:Class="AeroDesk.Views.OrderDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:AeroDesk.Views"
             Background="{StaticResource PageBackground}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" MaxWidth="900" HorizontalAlignment="Left">

            <!-- Header -->
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Order.RecordLocator}" FontSize="26" FontWeight="Bold" Margin="0,0,12,0"/>
                <Border Style="{StaticResource Pill}" VerticalAlignment="Center" Margin="0,0,8,0">
                    <TextBlock Text="{Binding Order.OrderId}"/>
                </Border>
                <Border Style="{StaticResource Pill}" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Order.Status}" FontWeight="SemiBold"/>
                </Border>
                <Button Content="🔄" Style="{StaticResource GhostButton}" Padding="8,4" Margin="12,0,0,0"
                        ToolTip="Reload from the order store" Command="{Binding RefreshCommand}"/>
            </StackPanel>
            <TextBlock Text="{Binding TotalLine}" FontSize="15" FontWeight="SemiBold" Margin="0,6,0,4"/>

            <ProgressBar Height="3" IsIndeterminate="{Binding IsBusy}" BorderThickness="0" Margin="0,4,0,0"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
            <TextBlock Text="{Binding ErrorText}" Foreground="{StaticResource Danger}" FontWeight="SemiBold"
                       TextWrapping="Wrap" Margin="0,6,0,4">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ErrorText}" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Pay bar (PendingPayment only) -->
            <Border Style="{StaticResource Card}" Background="#FFF7E6" Margin="0,12,0,12"
                    Visibility="{Binding IsPendingPayment, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⏳ Awaiting payment." VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,16,0"/>
                    <TextBlock Text="Token" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox Text="{Binding CardToken}" Width="150" VerticalContentAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="Last 4" Style="{StaticResource FieldLabel}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox Text="{Binding CardLast4}" Width="60" VerticalContentAlignment="Center" Margin="0,0,10,0"/>
                    <Button Content="💳 Take payment" Style="{StaticResource PrimaryButton}" Command="{Binding PayCommand}"/>
                </StackPanel>
            </Border>

            <!-- Itinerary + passengers side by side -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,6,12">
                    <StackPanel>
                        <TextBlock Text="Itinerary" Style="{StaticResource H2}"/>
                        <ItemsControl ItemsSource="{Binding Order.Segments}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Margin="0,2">
                                        <Run Text="{Binding FlightNumber, Mode=OneWay}" FontWeight="SemiBold"/>
                                        <Run Text="{Binding Origin, Mode=OneWay}"/><Run Text="→"/><Run Text="{Binding Destination, Mode=OneWay}"/>
                                        <Run Text="{Binding DepartureUtc, Mode=OneWay, StringFormat='  ddd d MMM HH:mm'}"/>
                                        <Run Text="{Binding ArrivalUtc, Mode=OneWay, StringFormat='– HH:mm '}"/>
                                        <Run Text="{Binding Equipment, Mode=OneWay}" Foreground="#888"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource Card}" Margin="6,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Passengers" Style="{StaticResource H2}"/>
                        <ItemsControl ItemsSource="{Binding Order.Passengers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Margin="0,2">
                                        <Run Text="{Binding Title, Mode=OneWay}"/>
                                        <Run Text="{Binding GivenName, Mode=OneWay}"/>
                                        <Run Text="{Binding Surname, Mode=OneWay}" FontWeight="SemiBold"/>
                                        <Run Text="{Binding Type, Mode=OneWay, StringFormat='({0})'}" Foreground="#888"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Current services -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Seats, extras &amp; documents" Style="{StaticResource H2}"/>
                    <ItemsControl ItemsSource="{Binding Order.Seats}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Margin="0,2">
                                    <Run Text="💺 Seat"/>
                                    <Run Text="{Binding SeatNumber, Mode=OneWay}" FontWeight="SemiBold"/>
                                    <Run Text="{Binding SegmentId, Mode=OneWay, StringFormat='on {0}'}"/>
                                    <Run Text="{Binding PassengerId, Mode=OneWay, StringFormat='for {0}'}"/>
                                    <Run Text="{Binding Price.Total, Mode=OneWay, StringFormat='— {0:N2}'}"/>
                                </TextBlock>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <ItemsControl ItemsSource="{Binding Order.Ancillaries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <TextBlock VerticalAlignment="Center">
                                        <Run Text="🧳"/>
                                        <Run Text="{Binding Name, Mode=OneWay}"/>
                                        <Run Text="{Binding SegmentId, Mode=OneWay, StringFormat='on {0}'}"/>
                                        <Run Text="{Binding PassengerId, Mode=OneWay, StringFormat='for {0}'}"/>
                                        <Run Text="{Binding Price.Total, Mode=OneWay, StringFormat='— {0:N2}'}"/>
                                    </TextBlock>
                                    <Button Content="Remove" Margin="10,0,0,0" Padding="8,2" FontSize="11"
                                            Style="{StaticResource GhostButton}"
                                            Visibility="{Binding DataContext.CanModify, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"
                                            Command="{Binding DataContext.RemoveAncillaryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <ItemsControl ItemsSource="{Binding Order.Documents}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Margin="0,2" FontFamily="Consolas">
                                    <Run Text="🎫"/>
                                    <Run Text="{Binding Kind, Mode=OneWay}"/>
                                    <Run Text="{Binding DocumentNumber, Mode=OneWay}" FontWeight="SemiBold"/>
                                    <Run Text="{Binding PassengerId, Mode=OneWay, StringFormat='— {0}'}"/>
                                </TextBlock>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Servicing: change flight (rebook) -->
            <Expander Header="Change flight" Margin="0,0,0,12"
                      Visibility="{Binding CanModify, Converter={StaticResource BoolToVis}}">
                <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="{Binding ChangeFeeLine}" Style="{StaticResource Hint}" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <StackPanel Width="230" Margin="0,0,10,0">
                                <TextBlock Text="Flight to change" Style="{StaticResource FieldLabel}"/>
                                <ComboBox ItemsSource="{Binding Order.Segments}" SelectedItem="{Binding ChangeSegment}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock>
                                                <Run Text="{Binding FlightNumber, Mode=OneWay}"/>
                                                <Run Text="{Binding Origin, Mode=OneWay}"/><Run Text="→"/><Run Text="{Binding Destination, Mode=OneWay}"/>
                                                <Run Text="{Binding DepartureUtc, Mode=OneWay, StringFormat='d MMM HH:mm'}"/>
                                            </TextBlock>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Width="150" Margin="0,0,10,0">
                                <TextBlock Text="New date" Style="{StaticResource FieldLabel}"/>
                                <DatePicker SelectedDate="{Binding ChangeDate}"/>
                            </StackPanel>
                            <Button Content="Find flights" Style="{StaticResource GhostButton}" VerticalAlignment="Bottom"
                                    Command="{Binding FindAlternativesCommand}"/>
                        </StackPanel>
                        <ListBox ItemsSource="{Binding Alternatives}" SelectedItem="{Binding SelectedAlternative}"
                                 MaxHeight="160" BorderThickness="1" BorderBrush="{StaticResource CardBorder}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Margin="2">
                                        <Run Text="{Binding FlightNumber, Mode=OneWay}" FontWeight="SemiBold"/>
                                        <Run Text="{Binding DepartureUtc, Mode=OneWay, StringFormat='ddd d MMM HH:mm'}"/>
                                        <Run Text="{Binding ArrivalUtc, Mode=OneWay, StringFormat='– HH:mm'}"/>
                                        <Run Text="{Binding Equipment, Mode=OneWay}" Foreground="#888"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Button Content="Rebook onto selected flight" Style="{StaticResource PrimaryButton}"
                                HorizontalAlignment="Left" Margin="0,10,0,0" Command="{Binding RebookCommand}"/>
                    </StackPanel>
                </Border>
            </Expander>

            <!-- Servicing: add seats/extras -->
            <Expander Header="Change seats &amp; add extras" Margin="0,0,0,12"
                      Visibility="{Binding CanModify, Converter={StaticResource BoolToVis}}">
                <StackPanel Margin="0,12,0,0">
                    <views:ExtrasSelectorView DataContext="{Binding Extras}"/>
                    <Button Content="Apply changes" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left"
                            Margin="0,12,0,0" Command="{Binding ApplyExtrasCommand}"/>
                </StackPanel>
            </Expander>

            <Button Content="✕ Cancel order" Style="{StaticResource GhostButton}" HorizontalAlignment="Left"
                    Foreground="{StaticResource Danger}" BorderBrush="{StaticResource Danger}"
                    Visibility="{Binding CanModify, Converter={StaticResource BoolToVis}}"
                    Command="{Binding CancelOrderCommand}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
