<UserControl x:Class="AeroDesk.Views.OrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:AeroDesk.ViewModels.Orders"
             Background="{StaticResource PageBackground}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Orders" Style="{StaticResource H1}"/>
            <StackPanel Orientation="Horizontal" Margin="0,4,0,16">
                <TextBox Width="280" VerticalContentAlignment="Center"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="OrderID (AT-…) or 6-letter record locator">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>
                <Button Content="Open" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0"
                        Command="{Binding SearchCommand}"/>
                <Button Content="🔄 Refresh" Style="{StaticResource GhostButton}" Margin="8,0,0,0"
                        Command="{Binding RefreshCommand}"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <ProgressBar Height="3" IsIndeterminate="{Binding IsBusy}" BorderThickness="0"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
            <TextBlock Text="{Binding StatusLine}" Style="{StaticResource Hint}" Margin="0,4,0,8"/>
        </StackPanel>

        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <DataGrid ItemsSource="{Binding Rows}" AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="None" BorderThickness="0"
                      RowHeight="34" SelectionMode="Single" Background="White">
                <DataGrid.InputBindings>
                    <MouseBinding MouseAction="LeftDoubleClick"
                                  Command="{Binding OpenCommand}"
                                  CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                </DataGrid.InputBindings>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Order" Binding="{Binding OrderId}" Width="170"/>
                    <DataGridTextColumn Header="Locator" Binding="{Binding Locator}" Width="80"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110"/>
                    <DataGridTextColumn Header="Route" Binding="{Binding Route}" Width="*"/>
                    <DataGridTextColumn Header="Departs" Binding="{Binding FirstDeparture}" Width="130"/>
                    <DataGridTextColumn Header="Pax" Binding="{Binding PaxLine}" Width="60"/>
                    <DataGridTextColumn Header="Total" Binding="{Binding Total}" Width="110"/>
                    <DataGridTextColumn Header="Created" Binding="{Binding Created}" Width="110"/>
                    <DataGridTemplateColumn Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Open" Style="{StaticResource GhostButton}" Padding="10,3"
                                        Command="{Binding OpenCommand}" CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
